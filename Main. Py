from fastapi import FastAPI
from routes import channels, episodes, search

app = FastAPI(
    title="Pokemon TV Reborn API",
    version="1.0"
)

app.include_router(channels.router)
app.include_router(episodes.router)
app.include_router(search.router)

@app.get("/")
def root():
    return {
        "name": "Pokemon TV Reborn",
        "status": "online",
        "version": "1.0"
    }
    
